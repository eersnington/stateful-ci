{
  "name": "stateful-ci",
  "version": "0.0.1",
  "private": false,
  "bin": {
    "stateful-ci": "./dist/index.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/cli/index.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts src/cli/index.ts --outdir dist --target node",
    "dev": "bun src/index.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/platform-node": "catalog:",
    "@stateful-ci/core": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:"
  }
}
