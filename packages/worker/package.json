{
  "name": "@stateful-ci/worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "wrangler dev src/index.ts",
    "test": "bun run test:node && bun run test:cloudflare",
    "test:cloudflare": "vitest run --config vitest.cloudflare.config.ts",
    "test:node": "vitest run --exclude '**/*.cloudflare.test.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stateful-ci/core": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "latest",
    "@cloudflare/workers-types": "latest",
    "@effect/vitest": "catalog:",
    "wrangler": "latest"
  }
}
